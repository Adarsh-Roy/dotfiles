# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Prevent accidental file overwrites with >
set -o noclobber
# Safety guardrail
alias rm="rm -i"

# Backup
setopt EXTENDED_HISTORY
export HISTFILE=~/.zsh_history
export HISTSIZE=10000
export SAVEHIST=10000

# keep sensitive things out of .zshrc
if [ -f ~/.zshrc.local ]; then
  source ~/.zshrc.local
fi


# Lazy-load conda on first use (saves ~100ms per shell startup).
# The first call to `conda` sources the real hook, then re-invokes itself.
conda() {
    unset -f conda
    __conda_setup="$('/opt/miniconda3/bin/conda' 'shell.zsh' 'hook' 2> /dev/null)"
    if [ $? -eq 0 ]; then
        eval "$__conda_setup"
    else
        if [ -f "/opt/miniconda3/etc/profile.d/conda.sh" ]; then
            . "/opt/miniconda3/etc/profile.d/conda.sh"
        else
            export PATH="/opt/miniconda3/bin:$PATH"
        fi
    fi
    unset __conda_setup
    conda "$@"
}

# Appearance
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="powerlevel10k/powerlevel10k"
plugins=(git)
# Skip oh-my-zsh's completion-dir permission audit (compaudit) — saves ~12ms
# on every shell startup. Safe because our completion dirs are managed via
# dotfiles and trusted.
export ZSH_DISABLE_COMPFIX=true
if [ -f "$ZSH/oh-my-zsh.sh" ]; then
  source "$ZSH/oh-my-zsh.sh"
fi
[[ -f ~/.p10k.zsh ]] && source ~/.p10k.zsh

# PATH extensions and EDITOR are in ~/.zshenv so non-interactive shells
# (kitty -e launches, cron, scripts) also pick them up. typeset -U there
# deduplicates, so nothing more needs to happen here.

# Neovim
alias nn='nvim'
alias nz='nn ~/.zshrc'
alias nlazy='NVIM_APPNAME=nvim-lazy nvim'
alias n='NVIM_APPNAME=nvim_0_12 ~/.local/share/bob/nvim-bin/nvim'

# Yazi
function y() {
  local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
  yazi "$@" --cwd-file="$tmp"
  if cwd="$(cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
    builtin cd -- "$cwd"
  fi
  rm -f -- "$tmp"
}


# Android Studio
export JAVA_HOME="/Applications/Android Studio.app/Contents/jbr/Contents/Home"

# Misc. aliases
alias lg='lazygit'
alias lgc='lazygit -p "$HOME/.local/share/chezmoi"'
alias cc='claude'
alias vea='source .venv/bin/activate'
alias mm='h-m-m'




# zoxide — ~0ms init, not worth lazy-loading
eval "$(zoxide init zsh)"

#System command aliases
alias ls="ls -F -G"


export XDG_CONFIG_HOME="$HOME/.config"

# vi mode with some commands
bindkey -v
bindkey -M viins '^E' edit-command-line
bindkey -M vicmd '^E' edit-command-line
bindkey -M viins '^R' history-incremental-search-backward

# Toggle desktop icons
toggledesktopicons() {
    # Get the current state: returns 0 if true (showing icons), 1 if false (hiding icons)
    local currentState=$(defaults read com.apple.finder CreateDesktop 2>/dev/null)

    if [ "$currentState" = "false" ]; then
        # If currently false, set to true
        defaults write com.apple.finder CreateDesktop true
        echo "Desktop icons shown."
    else
        # If currently true (or anything else), set to false
        defaults write com.apple.finder CreateDesktop false
        echo "Desktop icons hidden."
    fi
    # Restart Finder to apply changes
    killall Finder
}

notify() {
    local exit_status=$?
    if [ $exit_status -eq 0 ]; then
        osascript -e 'display notification "Command completed successfully" with title "Terminal"'
        say "Command finished successfully"
    else
        osascript -e 'display notification "Command failed with error code '$exit_status'" with title "Terminal Failure"'
        say "Command failed"
    fi
}

snap() {
  local adb_bin="$HOME/Library/Android/sdk/platform-tools/adb"
  local dev=$($adb_bin devices | awk 'NR>1 && $2=="device" {print $1; exit}')
  
  if [ -z "$dev" ]; then
    echo "No device found. Is WiFi debugging on?"
    return 1
  fi

  # 1. Bypass noclobber with >|
  $adb_bin -s "$dev" exec-out screencap -p >| /tmp/snap.png && \
  sips -s format tiff /tmp/snap.png --out /tmp/snap.tiff &>/dev/null && \
  osascript -e 'set the clipboard to (read (POSIX file "/tmp/snap.tiff") as TIFF picture)' && \
  # 2. Bypass the rm alias with \rm -f
  \rm -f /tmp/snap.png /tmp/snap.tiff
  
  echo "Copied to clipboard! 🚀"
}
